<UserControl x:Class="StudentManagement.Desktop.Views.ClassDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:StudentManagement.Desktop.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance Type=vm:ClassDetailViewModel}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#0F172A" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header / Class info -->
            <RowDefinition Height="*" />    <!-- Student Roster Table -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24"
                Margin="0,0,0,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding ClassName, StringFormat='Lớp học: {0}'}" Style="{StaticResource HeaderTextStyle}" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="{Binding ClassId, StringFormat='Mã lớp: {0}'}" FontSize="14" Foreground="#64748B" Margin="0,0,24,0" />
                        <TextBlock Text="{Binding SiSo, StringFormat='Sĩ số: {0} học sinh'}" FontSize="14" Foreground="#64748B" />
                    </StackPanel>
                </StackPanel>

                <!-- Back button -->
                <Button Grid.Column="1"
                        Content="Quay lại"
                        Command="{Binding BackCommand}"
                        Height="38"
                        Width="100"
                        Background="#64748B"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        VerticalAlignment="Center">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- Data Grid Content -->
        <Grid Grid.Row="1">
            <!-- Loading Indicator -->
            <Border Background="#50FFFFFF"
                    Panel.ZIndex="10"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="8" />
                    <TextBlock Text="Đang tải danh sách học sinh..."
                               Margin="0,12,0,0"
                               Foreground="#475569"
                               HorizontalAlignment="Center"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <!-- Table -->
            <Border Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <DataGrid ItemsSource="{Binding StudentList}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              Background="Transparent"
                              RowHeight="40"
                              HeadersVisibility="Column"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Resources>
                            <!-- Column Header Style -->
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="12,10"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="Height" Value="42"/>
                            </Style>
                            <!-- Cell Style -->
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#EFF6FF" />
                                        <Setter Property="Foreground" Value="#1E40AF" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã HS" Binding="{Binding IdHocSinh}" Width="140" />
                            <DataGridTextColumn Header="Họ tên" Binding="{Binding Ten}" Width="200" />
                            <DataGridTextColumn Header="Giới tính" Binding="{Binding GioiTinh}" Width="100" />
                            <DataGridTextColumn Header="Năm sinh" Binding="{Binding NamSinh}" Width="120" />
                            <DataGridTextColumn Header="Địa chỉ" Binding="{Binding DiaChi}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty State -->
                    <StackPanel VerticalAlignment="Center" 
                                HorizontalAlignment="Center"
                                Visibility="{Binding StudentList.Count, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverted}">
                        <TextBlock Text="Lớp học chưa có học sinh nào"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#94A3B8"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Vui lòng thực hiện tiếp nhận học sinh vào lớp."
                                   FontSize="13"
                                   Foreground="#94A3B8"
                                   Margin="0,8,0,0"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
