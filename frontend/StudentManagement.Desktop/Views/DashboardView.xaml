<UserControl x:Class="StudentManagement.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:StudentManagement.Desktop.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}">

    <UserControl.Resources>
        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8FAFC" />
                                <Setter Property="BorderBrush" Value="#3B82F6" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#F1F5F9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Welcome Banner -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Bảng điều khiển"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#0F172A" />
                    <TextBlock Text="Hệ thống Quản lý Học sinh THPT"
                               FontSize="14"
                               Foreground="#64748B"
                               Margin="0,8,0,0" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#ECFDF5"
                        BorderBrush="#99F6E4"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14,10"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding VaiTro}"
                               Foreground="#0F766E"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <!-- Quick Access Grid -->
        <UniformGrid Grid.Row="1"
                     Columns="2"
                     Margin="-10,24,-10,0">

            <!-- Card 1: Student List -->
            <Button Style="{StaticResource CardButtonStyle}"
                    Command="{Binding DataContext.NavigateToStudentListCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                <StackPanel>
                    <TextBlock Text="🔍 Tra cứu học sinh"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#0F172A" />
                    <TextBlock Text="Xem danh sách toàn trường, tìm kiếm học sinh theo họ tên hoặc lớp, xem điểm trung bình học tập các học kỳ."
                               Foreground="#64748B"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"
                               FontSize="14" />
                </StackPanel>
            </Button>

            <!-- Card 2: Class List -->
            <Button Style="{StaticResource CardButtonStyle}"
                    Command="{Binding DataContext.NavigateToClassListCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                <StackPanel>
                    <TextBlock Text="🏫 Danh sách lớp"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#0F172A" />
                    <TextBlock Text="Danh sách lớp học, quản lý sĩ số, xem danh sách chi tiết từng lớp và thông tin hồ sơ của học sinh."
                               Foreground="#64748B"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"
                               FontSize="14" />
                </StackPanel>
            </Button>

            <!-- Card 3: Scores Entry -->
            <Button Style="{StaticResource CardButtonStyle}"
                    Command="{Binding DataContext.NavigateToScoresCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Visibility="{Binding CanAccessScores, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="📝 Nhập bảng điểm"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#0F172A" />
                    <TextBlock Text="Nhập và cập nhật điểm 15 phút, 1 tiết, điểm thi và điểm trung bình môn học cho các học sinh."
                               Foreground="#64748B"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"
                               FontSize="14" />
                </StackPanel>
            </Button>

            <!-- Card 4: Regulations (Admin Only) -->
            <Button Style="{StaticResource CardButtonStyle}"
                    Command="{Binding DataContext.NavigateToRegulationsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Visibility="{Binding CanManageRegulations, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="⚙️ Quy định hệ thống"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#0F172A" />
                    <TextBlock Text="Thay đổi các tham số quy định: độ tuổi nhập học, sĩ số tối đa, danh sách môn học và điểm đạt chuẩn."
                               Foreground="#64748B"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"
                               FontSize="14" />
                </StackPanel>
            </Button>

        </UniformGrid>
    </Grid>
</UserControl>
