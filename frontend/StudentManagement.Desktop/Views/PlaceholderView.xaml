<UserControl x:Class="StudentManagement.Desktop.Views.PlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:StudentManagement.Desktop.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance Type=vm:PlaceholderViewModel}">
    <Grid Margin="32">
        <Border Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="40">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🚧" FontSize="64" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding Title}"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#0F172A"
                           Margin="0,20,0,0"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding Description}"
                           FontSize="16"
                           Foreground="#64748B"
                           Margin="0,12,0,0"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="500"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
