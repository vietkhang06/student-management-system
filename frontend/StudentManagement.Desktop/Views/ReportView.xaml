<UserControl x:Class="StudentManagement.Desktop.Views.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:StudentManagement.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance Type=vm:ReportViewModel}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- Filter ComboBox -->
        <Style x:Key="FilterCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="175"/>
        </Style>

        <!-- Load button (indigo) -->
        <Style x:Key="LoadButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="98"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#52e5b9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#42d4a8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#A7F3D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stat card style -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="28,22"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="MinWidth" Value="190"/>
        </Style>

        <!-- Stat number style -->
        <Style x:Key="StatNumber" TargetType="TextBlock">
            <Setter Property="FontSize" Value="44"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Tab bar -->
            <RowDefinition Height="Auto"/>   <!-- Filter bar -->
            <RowDefinition Height="Auto"/>   <!-- Status -->
            <RowDefinition Height="*"/>      <!-- Results -->
        </Grid.RowDefinitions>

        <!-- ── Page Header ─────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="White" BorderBrush="#E2E8F0"
                BorderThickness="1" CornerRadius="10"
                Padding="24,20" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Báo cáo tổng kết"
                           FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
            </StackPanel>
        </Border>

        <!-- ── Tab bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="White" BorderBrush="#E2E8F0"
                BorderThickness="1" CornerRadius="10"
                Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Margin="12,0">
                <Button x:Name="BtnTabSubject"
                        Content="Tổng kết môn học"
                        Height="42" Padding="20,0"
                        FontSize="14" FontWeight="SemiBold"
                        Background="Transparent" BorderThickness="0,0,0,2"
                        BorderBrush="#0F172A" Foreground="#0F172A"
                        Cursor="Hand"
                        Click="TabSubjectClick"/>
                <Button x:Name="BtnTabSemester"
                        Content="Tổng kết học kỳ"
                        Height="42" Padding="20,0"
                        FontSize="14" FontWeight="SemiBold"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#64748B"
                        Cursor="Hand"
                        Click="TabSemesterClick"/>
            </StackPanel>
        </Border>

        <!-- ── Filter Bar ──────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="White" BorderBrush="#E2E8F0"
                BorderThickness="1" CornerRadius="10"
                Padding="20,16" Margin="0,0,0,16">
            <StackPanel>
                <ProgressBar IsIndeterminate="True" Height="5"
                             Margin="0,0,0,12"
                             Visibility="{Binding IsLoadingFilters, Converter={StaticResource BoolVis}}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" x:Name="SubjectFilterCol" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Lớp -->
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Lớp" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#64748B" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Classes}"
                                  SelectedItem="{Binding SelectedClass}"
                                  DisplayMemberPath="TenLop"
                                  Style="{StaticResource ModernComboBox}"/>
                    </StackPanel>

                    <!-- Môn học (subject tab only) -->
                    <StackPanel x:Name="SubjectFilterPanel" Grid.Column="1" Margin="0,0,16,0">
                        <TextBlock Text="Môn học" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#64748B" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Subjects}"
                                  SelectedItem="{Binding SelectedSubject}"
                                  DisplayMemberPath="TenMonHoc"
                                  Style="{StaticResource ModernComboBox}"/>
                    </StackPanel>

                    <!-- Học kỳ -->
                    <StackPanel Grid.Column="2" Margin="0,0,16,0">
                        <TextBlock Text="Học kỳ" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#64748B" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Terms}"
                                  SelectedItem="{Binding SelectedTerm}"
                                  Style="{StaticResource ModernComboBox}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <Run Text="{Binding TenHocKy}"/>
                                        <Run Text=" — "/>
                                        <Run Text="{Binding NamHoc}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Actions -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <!-- Subject report button -->
                        <Button x:Name="BtnLoadSubject"
                                Content="Xem báo cáo"
                                Command="{Binding LoadSubjectReportCommand}"
                                Style="{StaticResource LoadButton}"/>

                        <!-- Semester report button -->
                        <Button x:Name="BtnLoadSemester"
                                Content="Xem báo cáo"
                                Command="{Binding LoadSemesterReportCommand}"
                                Style="{StaticResource LoadButton}"
                                Visibility="Collapsed"/>

                        <!-- Loading spinner -->
                        <ProgressBar IsIndeterminate="True"
                                     Width="80" Height="8"
                                     VerticalAlignment="Center"
                                     Margin="12,0,0,0"
                                     Visibility="{Binding IsLoadingReport, Converter={StaticResource BoolVis}}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── Status Message ─────────────────────────────────────────── -->
        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="#EF4444"
                   Margin="0,0,0,12"
                   Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolVis}}"/>

        <!-- ── Results Area ────────────────────────────────────────────── -->
        <Grid Grid.Row="4">

            <!-- Subject Report Panel -->
            <Border x:Name="SubjectReportPanel"
                    Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="1" CornerRadius="10" Padding="32">
                <Grid>
                    <!-- Empty state -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSubjectReport}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Chọn lớp, môn học và học kỳ rồi nhấn Xem báo cáo"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#94A3B8" HorizontalAlignment="Center"/>
                        <TextBlock Text="Kết quả sẽ hiển thị tổng số học sinh, số đạt và tỉ lệ."
                                   FontSize="13" Foreground="#94A3B8"
                                   Margin="0,8,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Result -->
                    <StackPanel Visibility="{Binding HasSubjectReport, Converter={StaticResource BoolVis}}">
                        <TextBlock FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,4">
                            <Run Text="Tổng kết môn: "/>
                            <Run Text="{Binding SubjectReportSubject}" Foreground="#4F46E5"/>
                        </TextBlock>
                        <TextBlock FontSize="13" Foreground="#64748B" Margin="0,0,0,28">
                            <Run Text="Lớp "/>
                            <Run Text="{Binding SubjectReportClass}" FontWeight="SemiBold"/>
                            <Run Text=" — "/>
                            <Run Text="{Binding SubjectReportTerm}"/>
                        </TextBlock>

                        <StackPanel Orientation="Horizontal">
                            <!-- Sĩ số -->
                            <Border Background="#EFF6FF" Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock Text="Sĩ số" FontSize="20" Foreground="#3B82F6" FontWeight="SemiBold" TextAlignment="Center"/>
                                    <TextBlock Text="{Binding SubjectReportTongHocSinh}"
                                               Style="{StaticResource StatNumber}" Foreground="#1D4ED8" TextAlignment="Center"/>
                                    <TextBlock Text="học sinh" FontSize="15" Foreground="#93C5FD" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- Số đạt -->
                            <Border Background="#F0FDF4" Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock Text="Số lượng đạt" FontSize="20" Foreground="#16A34A" FontWeight="SemiBold" TextAlignment="Center"/>
                                    <TextBlock Text="{Binding SubjectReportSoLuongDat}"
                                               Style="{StaticResource StatNumber}" Foreground="#15803D" TextAlignment="Center"/>
                                    <TextBlock Text="học sinh" FontSize="15" Foreground="#86EFAC" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- Tỉ lệ -->
                            <Border Background="#FFF7ED" Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock Text="Tỉ lệ đạt" FontSize="20" Foreground="#EA580C" FontWeight="SemiBold" TextAlignment="Center"/>
                                    <TextBlock Text="{Binding SubjectReportTyLe}"
                                               Style="{StaticResource StatNumber}" Foreground="#C2410C" TextAlignment="Center"/>
                                    <TextBlock Text="trên tổng sĩ số" FontSize="15" Foreground="#FCA5A5" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Semester Report Panel -->
            <Border x:Name="SemesterReportPanel"
                    Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="1" CornerRadius="10" Padding="32"
                    Visibility="Collapsed">
                <Grid>
                    <!-- Empty state -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSemesterReport}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Chọn lớp và học kỳ rồi nhấn Xem báo cáo"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#94A3B8" HorizontalAlignment="Center"/>
                        <TextBlock Text="Kết quả sẽ hiển thị tổng số học sinh lên lớp và tỉ lệ."
                                   FontSize="13" Foreground="#94A3B8"
                                   Margin="0,8,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Result -->
                    <StackPanel Visibility="{Binding HasSemesterReport, Converter={StaticResource BoolVis}}">
                        <TextBlock FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,4">
                            <Run Text="Tổng kết học kỳ: "/>
                            <Run Text="{Binding SemesterReportTerm}" Foreground="#0284C7"/>
                        </TextBlock>
                        <TextBlock FontSize="13" Foreground="#64748B" Margin="0,0,0,28">
                            <Run Text="Lớp "/>
                            <Run Text="{Binding SemesterReportClass}" FontWeight="SemiBold"/>
                        </TextBlock>

                        <StackPanel Orientation="Horizontal">
                            <!-- Sĩ số -->
                            <Border Background="#EFF6FF" Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock Text="📋 Sĩ số" FontSize="13" Foreground="#3B82F6" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding SemesterReportTongHocSinh}"
                                               Style="{StaticResource StatNumber}" Foreground="#1D4ED8"/>
                                    <TextBlock Text="học sinh" FontSize="12" Foreground="#93C5FD"/>
                                </StackPanel>
                            </Border>
                            <!-- Số lên lớp -->
                            <Border Background="#F0FDF4" Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock Text="🎓 Số lượng lên lớp" FontSize="13" Foreground="#16A34A" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding SemesterReportSoLuongDat}"
                                               Style="{StaticResource StatNumber}" Foreground="#15803D"/>
                                    <TextBlock Text="học sinh" FontSize="12" Foreground="#86EFAC"/>
                                </StackPanel>
                            </Border>
                            <!-- Tỉ lệ -->
                            <Border Background="#FFF7ED" Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock Text="📈 Tỉ lệ lên lớp" FontSize="13" Foreground="#EA580C" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding SemesterReportTyLe}"
                                               Style="{StaticResource StatNumber}" Foreground="#C2410C"/>
                                    <TextBlock Text="trên tổng sĩ số" FontSize="12" Foreground="#FCA5A5"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
