<UserControl x:Class="StudentManagement.Desktop.Views.ScoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:StudentManagement.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance Type=vm:ScoreViewModel}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- ComboBox style -->
        <Style x:Key="FilterCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="180"/>
        </Style>

        <!-- Small inline save button -->
        <Style x:Key="SaveRowButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="72"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#93C5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Load scores button -->
        <Style x:Key="LoadButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#52e5b9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#42d4a8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#A7F3D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Editable score TextBox in DataGrid cell -->
        <Style x:Key="ScoreBox" TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#F0F9FF"/>
            <Setter Property="BorderBrush" Value="#BAE6FD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="#F1F5F9"/>
                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    <Setter Property="Foreground" Value="#64748B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid column header -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Height" Value="42"/>
        </Style>

        <!-- DataGrid cell -->
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                    <Setter Property="Foreground" Value="#1E40AF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Centered header style -->
        <Style x:Key="CenteredHeader" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Filter bar -->
            <RowDefinition Height="Auto"/>  <!-- Status message -->
            <RowDefinition Height="*"/>     <!-- Score table -->
        </Grid.RowDefinitions>

        <!-- ── Page Header ─────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="10"
                Padding="24,20"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Bảng điểm môn học"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#0F172A"/>
            </StackPanel>
        </Border>

        <!-- ── Filter Bar ──────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20,16"
                Margin="0,0,0,16">
            <StackPanel>
                <!-- Filter loading spinner -->
                <ProgressBar IsIndeterminate="True" Height="5"
                             Margin="0,0,0,12"
                             Visibility="{Binding IsLoadingFilters, Converter={StaticResource BoolVis}}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Lớp -->
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Lớp" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#64748B" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Classes}"
                                  SelectedItem="{Binding SelectedClass}"
                                  DisplayMemberPath="TenLop"
                                  Style="{StaticResource ModernComboBox}"/>
                    </StackPanel>

                    <!-- Môn học -->
                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                        <TextBlock Text="Môn học" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#64748B" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Subjects}"
                                  SelectedItem="{Binding SelectedSubject}"
                                  DisplayMemberPath="TenMonHoc"
                                  Style="{StaticResource ModernComboBox}"/>
                    </StackPanel>

                    <!-- Học kỳ -->
                    <StackPanel Grid.Column="2" Margin="0,0,16,0">
                        <TextBlock Text="Học kỳ" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#64748B" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Terms}"
                                  SelectedItem="{Binding SelectedTerm}"
                                  Style="{StaticResource ModernComboBox}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <Run Text="{Binding TenHocKy}"/>
                                        <Run Text=" — "/>
                                        <Run Text="{Binding NamHoc}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Actions -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <!-- Load button -->
                        <Button Content="Tải bảng điểm"
                                Command="{Binding LoadScoresCommand}"
                                Style="{StaticResource LoadButton}"/>

                        <!-- Loading spinner for scores -->
                        <ProgressBar IsIndeterminate="True"
                                     Width="80" Height="8"
                                     VerticalAlignment="Center"
                                     Margin="12,0,0,0"
                                     Visibility="{Binding IsLoadingScores, Converter={StaticResource BoolVis}}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── Status Message ─────────────────────────────────────────── -->
        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="#64748B"
                   Margin="0,0,0,12"
                   Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolVis}}"/>

        <!-- ── Score Table ─────────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Margin="0,60">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasScores}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Chọn lớp, môn học và học kỳ rồi nhấn Tải bảng điểm"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#94A3B8"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Sau đó bạn có thể nhập điểm trực tiếp trong bảng."
                               FontSize="13"
                               Foreground="#94A3B8"
                               Margin="0,8,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Data grid -->
                <DataGrid ItemsSource="{Binding ScoreRows}"
                          AutoGenerateColumns="False"
                          IsReadOnly="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          Background="Transparent"
                          RowHeight="48"
                          HeadersVisibility="Column"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasScores}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>

                    <DataGrid.Columns>
                        <!-- Mã HS -->
                        <DataGridTextColumn Header="Mã HS"
                                            Binding="{Binding IdHocSinh}"
                                            Width="130"
                                            IsReadOnly="True"/>

                        <!-- Họ tên -->
                        <DataGridTextColumn Header="Họ tên"
                                            Binding="{Binding TenHocSinh}"
                                            Width="*"
                                            IsReadOnly="True"/>

                        <!-- Điểm 15' (editable) -->
                        <DataGridTemplateColumn Header="Điểm 15'" Width="100" HeaderStyle="{StaticResource CenteredHeader}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Diem15, UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="{Binding DataContext.IsReadOnlyScores, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                             Style="{StaticResource ScoreBox}"
                                             HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Điểm 1 tiết (editable) -->
                        <DataGridTemplateColumn Header="Điểm 1 tiết" Width="100" HeaderStyle="{StaticResource CenteredHeader}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Diem45, UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="{Binding DataContext.IsReadOnlyScores, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                             Style="{StaticResource ScoreBox}"
                                             HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Điểm TB (read-only, computed by backend) -->
                        <DataGridTemplateColumn Header="Điểm TB" Width="90" HeaderStyle="{StaticResource CenteredHeader}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DiemTb}"
                                               FontWeight="Bold"
                                               Foreground="#0F172A"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Save / Status -->
                        <DataGridTemplateColumn Header="Lưu" Width="280">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0">
                                        <Button Content="💾 Lưu"
                                                Command="{Binding DataContext.SaveRowCommand,
                                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding DataContext.CanEditScores, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                Style="{StaticResource SaveRowButton}"/>
                                        <TextBlock Text="{Binding SaveStatus}"
                                                   FontSize="12"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SaveStatus}" Value="✅">
                                                            <Setter Property="Foreground" Value="#16A34A"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
