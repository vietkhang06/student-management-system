<Window x:Class="StudentManagement.Desktop.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StudentManagement.Desktop.ViewModels"
        xmlns:views="clr-namespace:StudentManagement.Desktop.Views"
        Title="Phần mềm Quản lý học sinh"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <!-- DataTemplates for navigation -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentListViewModel}">
            <views:StudentListView DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClassListViewModel}">
            <views:ClassListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClassDetailViewModel}">
            <views:ClassDetailView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PlaceholderViewModel}">
            <views:PlaceholderView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AdmissionViewModel}">
            <views:AdmissionView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ScoreViewModel}">
            <views:ScoreView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportViewModel}">
            <views:ReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RegulationViewModel}">
            <views:RegulationView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SystemAdminViewModel}">
            <views:SystemAdminView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <views:HistoryView />
        </DataTemplate>

        <Storyboard x:Key="CloseMenuAnimation">
            <DoubleAnimation Storyboard.TargetName="SidebarBorder"
                              Storyboard.TargetProperty="Width"
                              To="70" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="OpenMenuAnimation">
            <DoubleAnimation Storyboard.TargetName="SidebarBorder"
                              Storyboard.TargetProperty="Width"
                              To="260" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Style TargetType="Button" x:Key="MenuButtonStyle">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <Grid Width="260" HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Content="{TemplateBinding Content}" Grid.ColumnSpan="2"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E293B"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Path" x:Key="MenuIconStyle">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
            <Setter Property="Grid.Column" Value="0"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="MenuTextStyle">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Grid.Column" Value="1"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
        </Style>

        <!-- SVG Geometries -->
        <Geometry x:Key="IconDashboard">M21 20C21 20.5523 20.5523 21 20 21H4C3.44772 21 3 20.5523 3 20V9.48907C3 9.18048 3.14247 8.88917 3.38606 8.69972L11.3861 2.47749C11.7472 2.19663 12.2528 2.19663 12.6139 2.47749L20.6139 8.69972C20.8575 8.88917 21 9.18048 21 9.48907V20ZM19 19V9.97815L12 4.53371L5 9.97815V19H19Z</Geometry>
        <Geometry x:Key="IconStudentSearch">M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z</Geometry>
        <Geometry x:Key="IconClassList">M12 3L1 9l11 6 9-4.91V17h2V9L12 3zM4.75 12.04v4.22c0 2.21 3.25 4 7.25 4s7.25-1.79 7.25-4v-4.22l-7.25 3.95-7.25-3.95z</Geometry>
        <Geometry x:Key="IconAdmission">M15 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm-9-2V7H4v3H1v2h3v3h2v-3h3v-2H6zm9 4c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z</Geometry>
        <Geometry x:Key="IconScores">M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z</Geometry>
        <Geometry x:Key="IconReports">M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z</Geometry>
        <Geometry x:Key="IconRegulations">M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z</Geometry>
        <Geometry x:Key="IconSystemAdmin">M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z</Geometry>
        <Geometry x:Key="IconHistory">M13 3C7.48 3 3 7.48 3 13s4.48 10 10 10 10-4.48 10-10S18.52 3 13 3zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H12v6l5.25 3.15.75-1.23-4.5-2.67z</Geometry>
        <Geometry x:Key="IconLogout">M10.09 15.59L11.5 17l5-5-5-5-1.41 1.41L12.67 11H3v2h9.67l-2.58 2.59zM19 3H5c-1.11 0-2 .9-2 2v4h2V5h14v14H5v-4H3v4c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z</Geometry>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar Panel -->
        <Border x:Name="SidebarBorder"
                Grid.Column="0"
                Width="70"
                Background="#0F172A"
                Panel.ZIndex="100"
                ClipToBounds="True"
                MouseEnter="Sidebar_MouseEnter"
                MouseLeave="Sidebar_MouseLeave">
            
            <Border.Effect>
                <DropShadowEffect Color="#64748B" Direction="0" ShadowDepth="4" BlurRadius="20" Opacity="0.15"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo & Brand Header -->
                <StackPanel Grid.Row="0" Margin="0,15,0,30">
                    <Grid Width="260" HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </StackPanel>

                <!-- Navigation List -->
                <ScrollViewer Grid.Row="1" 
                              HorizontalScrollBarVisibility="Disabled" 
                              VerticalScrollBarVisibility="Hidden"
                              Focusable="False">
                    <StackPanel>
                        <!-- Navigation Buttons -->
                        <Button Command="{Binding NavigateToDashboardCommand}" Style="{StaticResource MenuButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="{StaticResource IconDashboard}" Style="{StaticResource MenuIconStyle}"/>
                                <TextBlock Text="Bảng điều khiển" Style="{StaticResource MenuTextStyle}"/>
                            </Grid>
                        </Button>

                        <Button Command="{Binding NavigateToStudentListCommand}" Style="{StaticResource MenuButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="{StaticResource IconStudentSearch}" Style="{StaticResource MenuIconStyle}"/>
                                <TextBlock Text="Tra cứu học sinh" Style="{StaticResource MenuTextStyle}"/>
                            </Grid>
                        </Button>

                        <Button Command="{Binding NavigateToClassListCommand}" Style="{StaticResource MenuButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="{StaticResource IconClassList}" Style="{StaticResource MenuIconStyle}"/>
                                <TextBlock Text="Danh sách lớp" Style="{StaticResource MenuTextStyle}"/>
                            </Grid>
                        </Button>

                        <Button Command="{Binding NavigateToAdmissionCommand}" 
                                Style="{StaticResource MenuButtonStyle}"
                                Visibility="{Binding CanReceiveStudents, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="{StaticResource IconAdmission}" Style="{StaticResource MenuIconStyle}"/>
                                <TextBlock Text="Tiếp nhận học sinh" Style="{StaticResource MenuTextStyle}"/>
                            </Grid>
                        </Button>

                        <Button Command="{Binding NavigateToScoresCommand}" 
                                Style="{StaticResource MenuButtonStyle}"
                                Visibility="{Binding CanAccessScores, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="{StaticResource IconScores}" Style="{StaticResource MenuIconStyle}"/>
                                <TextBlock Text="Nhập bảng điểm" Style="{StaticResource MenuTextStyle}"/>
                            </Grid>
                        </Button>

                        <Button Command="{Binding NavigateToReportsCommand}" 
                                Style="{StaticResource MenuButtonStyle}"
                                Visibility="{Binding CanAccessReports, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="{StaticResource IconReports}" Style="{StaticResource MenuIconStyle}"/>
                                <TextBlock Text="Báo cáo tổng kết" Style="{StaticResource MenuTextStyle}"/>
                            </Grid>
                        </Button>

                        <Button Command="{Binding NavigateToRegulationsCommand}" 
                                Style="{StaticResource MenuButtonStyle}"
                                Visibility="{Binding CanManageRegulations, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="{StaticResource IconRegulations}" Style="{StaticResource MenuIconStyle}"/>
                                <TextBlock Text="Quy định hệ thống" Style="{StaticResource MenuTextStyle}"/>
                            </Grid>
                        </Button>

                        <Button Command="{Binding NavigateToSystemAdminCommand}" 
                                Style="{StaticResource MenuButtonStyle}"
                                Visibility="{Binding CanManageSystem, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="{StaticResource IconSystemAdmin}" Style="{StaticResource MenuIconStyle}"/>
                                <TextBlock Text="Quản trị hệ thống" Style="{StaticResource MenuTextStyle}"/>
                            </Grid>
                        </Button>

                        <Button Command="{Binding NavigateToHistoryCommand}" 
                                Style="{StaticResource MenuButtonStyle}"
                                Visibility="{Binding CanManageSystem, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="{StaticResource IconHistory}" Style="{StaticResource MenuIconStyle}"/>
                                <TextBlock Text="Lịch sử hệ thống" Style="{StaticResource MenuTextStyle}"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer Profile Card & Logout -->
                <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                    <!-- Logout button -->
                    <Button Command="{Binding LogoutCommand}" Style="{StaticResource MenuButtonStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Data="{StaticResource IconLogout}" Style="{StaticResource MenuIconStyle}" Fill="#EF4444"/>
                            <TextBlock Text="Đăng xuất" Style="{StaticResource MenuTextStyle}" Foreground="#EF4444" FontWeight="Bold"/>
                        </Grid>
                    </Button>

                    <!-- Clickable Profile Card -->
                    <Button Command="{Binding ShowProfileCommand}"
                            Background="#1E293B"
                            BorderBrush="#334155"
                            BorderThickness="0,1,0,0"
                            Height="64"
                            HorizontalAlignment="Stretch"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" BorderThickness="0,1,0,0" BorderBrush="#334155">
                                    <Grid Width="260" HorizontalAlignment="Left">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Width="36" Height="36" CornerRadius="18" Background="#F0F9FF" BorderBrush="#38BDF8" BorderThickness="1.5">
                                                <TextBlock Text="{Binding Initials}" 
                                                           FontSize="12" 
                                                           FontWeight="Bold" 
                                                           Foreground="#0284C7"
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="5,0,0,0">
                                            <TextBlock Text="{Binding TenNguoiDung}" FontWeight="Bold" Foreground="White" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding VaiTroHienThi}" Foreground="#94A3B8" FontSize="10" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#334155"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentPageViewModel}" />
    </Grid>
</Window>
