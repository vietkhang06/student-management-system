<Window x:Class="StudentManagement.Desktop.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StudentManagement.Desktop.ViewModels"
        xmlns:views="clr-namespace:StudentManagement.Desktop.Views"
        Title="Phần mềm Quản lý học sinh"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <!-- DataTemplates for navigation -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentListViewModel}">
            <views:StudentListView DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClassListViewModel}">
            <views:ClassListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClassDetailViewModel}">
            <views:ClassDetailView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PlaceholderViewModel}">
            <views:PlaceholderView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AdmissionViewModel}">
            <views:AdmissionView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ScoreViewModel}">
            <views:ScoreView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportViewModel}">
            <views:ReportView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RegulationViewModel}">
            <views:RegulationView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SystemAdminViewModel}">
            <views:SystemAdminView />
        </DataTemplate>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#F1F5F9" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#475569" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar Panel -->
        <Border Grid.Column="0"
                Background="#0F172A"
                Padding="20">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Quản lý học sinh"
                               Foreground="White"
                               FontSize="21"
                               FontWeight="Bold"
                               TextWrapping="Wrap" />

                    <!-- Clickable Profile Card -->
                    <Button Command="{Binding ShowProfileCommand}"
                            Background="#1E293B"
                            BorderBrush="#334155"
                            BorderThickness="1"
                            Margin="0,18,0,24"
                            Padding="12,10"
                            HorizontalAlignment="Stretch"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Avatar Icon -->
                                        <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16" Background="#38BDF8" Margin="0,0,10,0" VerticalAlignment="Center">
                                            <TextBlock Text="👤" Foreground="White" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <!-- User details -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TenNguoiDung}" Foreground="White" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding VaiTroHienThi}" Foreground="#94A3B8" FontSize="10" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#334155"/>
                                        <Setter Property="BorderBrush" Value="#475569"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Sidebar Navigation Buttons -->
                    <Button Content="🏠 Bảng điều khiển" Style="{StaticResource MenuButtonStyle}" Command="{Binding NavigateToDashboardCommand}" />
                    <Button Content="🔍 Tra cứu học sinh" Style="{StaticResource MenuButtonStyle}" Command="{Binding NavigateToStudentListCommand}" />
                    <Button Content="🏫 Danh sách lớp" Style="{StaticResource MenuButtonStyle}" Command="{Binding NavigateToClassListCommand}" />
                    
                    <Button Content="📥 Tiếp nhận học sinh"
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding NavigateToAdmissionCommand}"
                            Visibility="{Binding CanReceiveStudents, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    
                    <Button Content="📝 Nhập bảng điểm"
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding NavigateToScoresCommand}"
                            Visibility="{Binding CanAccessScores, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    
                    <Button Content="📊 Báo cáo tổng kết"
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding NavigateToReportsCommand}"
                            Visibility="{Binding CanAccessReports, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    
                    <Button Content="⚙️ Quy định hệ thống"
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding NavigateToRegulationsCommand}"
                            Visibility="{Binding CanManageRegulations, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    
                    <Button Content="🛠️ Quản trị hệ thống"
                            Style="{StaticResource MenuButtonStyle}"
                            Command="{Binding NavigateToSystemAdminCommand}"
                            Visibility="{Binding CanManageSystem, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>

                <!-- Logout Button at bottom -->
                <Button DockPanel.Dock="Bottom"
                        Content="Đăng xuất"
                        Command="{Binding LogoutCommand}"
                        Height="42"
                        Background="#334155"
                        Foreground="White"
                        BorderBrush="#475569"
                        BorderThickness="1"
                        FontWeight="SemiBold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#475569" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#1E293B" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentPageViewModel}" />
    </Grid>
</Window>
