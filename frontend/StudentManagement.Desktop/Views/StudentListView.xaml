<UserControl x:Class="StudentManagement.Desktop.Views.StudentListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:StudentManagement.Desktop.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance Type=vm:StudentListViewModel}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#0F172A" />
        </Style>
        <Style x:Key="ActionBtnPrimary" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E293B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionBtnSecondary" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionBtnDanger" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#FEF2F2"/>
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FEE2E2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="Auto" /> <!-- Filters -->
            <RowDefinition Height="*" />    <!-- Table -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24"
                Margin="0,0,0,16">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Quản lý học sinh" Style="{StaticResource HeaderTextStyle}" />
                    <TextBlock Text="Tra cứu, thêm mới, chỉnh sửa và xóa học sinh"
                               Foreground="#64748B" FontSize="13" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- CRUD Buttons — visible only for BanQuanLy -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Visibility="{Binding IsBanQuanLy, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button Content="Sửa"
                            Command="{Binding EditStudentCommand}"
                            IsEnabled="{Binding IsStudentSelected}"
                            Style="{StaticResource ActionBtnSecondary}"
                            Margin="0,0,8,0"/>
                    <Button Content="Xóa"
                            Command="{Binding DeleteStudentCommand}"
                            IsEnabled="{Binding IsStudentSelected}"
                            Style="{StaticResource ActionBtnDanger}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Search Name -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="Họ và tên" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6" />
                    <TextBox Text="{Binding SearchName, UpdateSourceTrigger=PropertyChanged}"
                             Height="38"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             BorderBrush="#CBD5E1"
                             BorderThickness="1" />
                </StackPanel>

                <!-- Filter Class -->
                <StackPanel Grid.Column="1" Margin="0,0,16,0">
                    <TextBlock Text="Lớp học" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6" />
                    <ComboBox ItemsSource="{Binding ClassList}"
                              SelectedItem="{Binding SelectedClass}"
                              DisplayMemberPath="TenLop"
                              Height="38"
                              BorderBrush="#CBD5E1"
                              BorderThickness="1"
                              VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="Tìm kiếm"
                            Command="{Binding SearchCommand}"
                            Style="{StaticResource ActionBtnPrimary}"
                            Margin="0,0,8,0"/>
                    <Button Content="Làm mới"
                            Command="{Binding ResetCommand}"
                            Style="{StaticResource ActionBtnSecondary}"
                            Margin="0,0,8,0"/>
                    <Button Content="↺ Tải lại"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource ActionBtnSecondary}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Data Grid Content -->
        <Grid Grid.Row="2">
            <!-- Loading Indicator -->
            <Border Background="#80FFFFFF"
                    Panel.ZIndex="10"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="8" />
                    <TextBlock Text="Đang tải dữ liệu học sinh..."
                               Margin="0,12,0,0"
                               Foreground="#475569"
                               HorizontalAlignment="Center"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <!-- Table -->
            <Border Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <DataGrid ItemsSource="{Binding StudentList}"
                              SelectedItem="{Binding SelectedStudent, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              Background="Transparent"
                              RowHeight="40"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Resources>
                            <!-- Column Header Style -->
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="12,10"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="Height" Value="42"/>
                            </Style>
                            <!-- Row Style -->
                            <Style TargetType="DataGridRow">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#EFF6FF"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                            <!-- Cell Style -->
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#EFF6FF" />
                                        <Setter Property="Foreground" Value="#1E40AF" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã học sinh" Binding="{Binding IdHocSinh}" Width="150" />
                            <DataGridTextColumn Header="Họ và tên" Binding="{Binding Ten}" Width="*" />
                            <DataGridTextColumn Header="Lớp" Binding="{Binding TenLop}" Width="120" />
                            <DataGridTextColumn Header="TB Học kỳ I" Binding="{Binding TbHocKy1Display}" Width="150" />
                            <DataGridTextColumn Header="TB Học kỳ II" Binding="{Binding TbHocKy2Display}" Width="150" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty State -->
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Visibility="{Binding StudentList.Count, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverted}">
                        <TextBlock Text="📭 Không tìm thấy học sinh nào"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#94A3B8"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Vui lòng kiểm tra lại điều kiện tìm kiếm hoặc phân công giảng dạy của bạn."
                                   FontSize="13"
                                   Foreground="#94A3B8"
                                   Margin="0,8,0,0"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
