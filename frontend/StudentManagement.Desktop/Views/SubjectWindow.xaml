<Window x:Class="StudentManagement.Desktop.Views.SubjectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông tin môn học" 
        Height="360" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <!-- Standard text labels -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Form TextBoxes -->
        <Style x:Key="FormTxt" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <!-- Close button style -->
        <Style x:Key="CloseBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#0F172A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Color="#0F172A" Opacity="0.1"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title Bar -->
                <RowDefinition Height="*"/>    <!-- Content Fields -->
                <RowDefinition Height="Auto"/> <!-- Action bar -->
            </Grid.RowDefinitions>

            <!-- Header Title -->
            <Border Grid.Row="0" Padding="24,18" Background="#F8FAFC" CornerRadius="15,15,0,0" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock x:Name="TxtTitle" Text="Thêm môn học mới" FontSize="16" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center"/>
                    <Button Content="✕" 
                            Style="{StaticResource CloseBtnStyle}"
                            Width="32" Height="32"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Click="Cancel_Click"/>
                </Grid>
            </Border>

            <!-- Scrollable input form -->
            <StackPanel Grid.Row="1" Margin="24,20">
                <TextBlock Text="Mã môn học *" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtIdMonHoc" Style="{StaticResource FormTxt}"/>

                <TextBlock Text="Tên môn học *" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtTenMonHoc" Style="{StaticResource FormTxt}"/>

                <CheckBox x:Name="ChkActive" Content="Trạng thái sử dụng (Cho phép giảng dạy và nhập điểm)" FontWeight="SemiBold" Foreground="#1E293B" IsChecked="True" Margin="0,4,0,12"/>
            </StackPanel>

            <!-- Actions buttons -->
            <Border Grid.Row="2" Padding="24,16" Background="#F8FAFC" CornerRadius="0,0,15,15" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Hủy" 
                            Click="Cancel_Click"
                            Width="80" Height="36" Margin="0,0,8,0"
                            Background="#F1F5F9" Foreground="#475569"
                            BorderBrush="#CBD5E1" BorderThickness="1"
                            FontWeight="SemiBold" FontSize="13"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="Lưu" 
                            Click="Save_Click"
                            Width="90" Height="36"
                            Background="#0F172A" Foreground="White"
                            FontWeight="SemiBold" FontSize="13"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
